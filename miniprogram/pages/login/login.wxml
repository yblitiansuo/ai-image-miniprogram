<!--pages/login/login.wxml-->
<view class="container" data-theme="{{theme}}">
  <view class="login-card">
    <view class="brand">
      <text class="title">AI 图片生成</text>
      <text class="subtitle">电商商品图，一键生成</text>
    </view>

    <button class="wechat-login" bindtap="handleMockLogin" loading="{{isLoggingIn}}">
      <text class="btn-text">{{isLoggingIn ? '登录中...' : '微信授权登录'}}</text>
    </button>

    <view class="privacy">
      <text>继续即表示同意《用户协议》和《隐私政策》</text>
    </view>
  </view>
</view>
