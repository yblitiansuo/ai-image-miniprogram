/* pages/purchase/purchase.wxss */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.package-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.package-item {
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  background-color: var(--card-bg);
  transition: all 0.2s;
}

.package-item.selected {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(24, 144, 255, 0.2);
}

.package-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.package-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.package-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.package-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.package-quota {
  font-size: 24rpx;
  color: var(--primary-color);
}

.action-buttons {
  margin-top: 32rpx;
}

.action-buttons .btn {
  width: 100%;
}
