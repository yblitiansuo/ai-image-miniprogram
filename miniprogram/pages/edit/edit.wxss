/* pages/edit/edit.wxss */
page {
  background: #000;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.canvas-container {
  position: relative;
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

#editCanvas {
  width: 100%;
  height: 100%;
}

.toolbar {
  background: #1a1a1a;
  padding: 16rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
  justify-content: flex-end;
}

.btn {
  background: #333;
  color: #fff;
  border: none;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn:active {
  background: #444;
}

.btn-primary {
  background: #1890ff;
}

.btn-primary:active {
  background: #096dd9;
}

.aspect-options {
  display: flex;
  gap: 12rpx;
}

.aspect-btn {
  padding: 12rpx 24rpx;
  background: #333;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.aspect-btn.active {
  background: #1890ff;
}

.crop-info {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.check-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
  background-color: rgba(82, 196, 26, 0.9);
  color: white;
  border-radius: 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}