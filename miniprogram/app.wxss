/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主题变量 */
[data-theme="light"] {
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --border-color: #e0e0e0;
  --primary-color: #1890ff;
  --primary-hover: #40a9ff;
}

[data-theme="dark"] {
  --bg-color: #1a1a1a;
  --card-bg: #2d2d2d;
  --text-primary: #f0f0f0;
  --text-secondary: #aaaaaa;
  --border-color: #444444;
  --primary-color: #177ddc;
  --primary-hover: #3c9ae8;
}

/* 通用卡片 */
.card {
  background-color: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 按钮样式 */
.btn {
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx 48rpx;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: var(--primary-color);
  color: white;
}

.btn-primary:active {
  background-color: var(--primary-hover);
}

.btn-secondary {
  background-color: transparent;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

.btn-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 输入框 */
.input {
  background-color: var(--card-bg);
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  padding: 20rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

.input:focus {
  border-color: var(--primary-color);
}

/* 文本 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 图标按钮 */
.icon-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: var(--primary-color);
  color: white;
  font-size: 40rpx;
  margin: 0 auto;
}

.icon-btn-secondary {
  background-color: var(--border-color);
  color: var(--text-primary);
}
