# AI 图片生成小程序 - 环境配置模板
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写所有需要申请的配置项
# 3. 本地联调：python main.py
# 4. 部署到云托管：云托管控制台会自动读取环境变量

# ============================================================
# MySQL 数据库配置
# ============================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=ai_image
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# ============================================================
# Redis (Celery 消息队列)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# 火山引擎 Seedream API
# ============================================================
ARK_API_KEY=your_volcengine_api_key_here
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_SIZE=2K

# ============================================================
# 腾讯云 COS 存储
# ============================================================
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name-here  # 例如：ai-image-123456789
COS_SECRET_ID=your_cos_secret_id_here
COS_SECRET_KEY=your_cos_secret_key_here

# ============================================================
# JWT 认证
# ============================================================
# 生成随机密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-random-secret-key-here

# ============================================================
# 小程序配置（可选，模拟登录用）
# ============================================================
WECHAT_APPID=your_wechat_appid_here
WECHAT_SECRET=your_wechat_secret_here

# ============================================================
# 运行模式（生产环境请设置为 false）
# ============================================================
DEV_MODE=false

# ============================================================
# CORS 白名单（英文逗号分隔）
# ============================================================
CORS_ALLOW_ORIGINS=https://api.your-domain.com

# ============================================================
# 后端服务端口（统一 9999）
# ============================================================
BACKEND_PORT=9999

# ============================================================
# Celery 任务配置
# ============================================================
TASK_TIMEOUT_SECONDS=1800
TASK_MAX_RETRIES=2
TASK_RETRY_DELAY=60

# ============================================================
# 结果清理策略
# ============================================================
RESULT_RETENTION_DAYS=7
